# ========================================
# Hire1Percent API Gateway
# Environment Configuration
# ========================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Logging ---
LOG_LEVEL=debug

# --- Downstream Microservice URLs ---
AUTH_SERVICE_URL=http://localhost:5001
JOB_SERVICE_URL=http://localhost:5002
CANDIDATE_SERVICE_URL=http://localhost:5003
RECRUITER_SERVICE_URL=http://localhost:5004
ADMIN_SERVICE_URL=http://localhost:5005
ASSESSMENT_SERVICE_URL=http://localhost:5006
INTERVIEW_SERVICE_URL=http://localhost:5007
RESUME_SERVICE_URL=http://localhost:5008
NOTIFICATION_SERVICE_URL=http://localhost:5009

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# --- Gateway Timeouts ---
GATEWAY_TIMEOUT_MS=30000
PROXY_TIMEOUT_MS=5000

# --- Circuit Breaker ---
CIRCUIT_BREAKER_RESET_TIMEOUT_MS=30000
CIRCUIT_BREAKER_ERROR_THRESHOLD=50
CIRCUIT_BREAKER_VOLUME_THRESHOLD=5

# --- Auth Cache ---
AUTH_CACHE_ENABLED=true
AUTH_CACHE_TTL_MS=2000

# --- Auth Service Client ---
AUTH_SERVICE_CLIENT_RETRIES=2

# --- Boot Config ---
BOOT_FAIL_FAST=true

# --- CORS ---
CORS_ORIGIN=http://localhost:3000

# --- Shutdown ---
GRACEFUL_SHUTDOWN_TIMEOUT_MS=10000

