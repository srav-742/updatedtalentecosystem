# ========================================
# Hire1Percent Frontend Configuration
# ========================================

# Base API URL pointing to the API Gateway (or Local Backend)
VITE_API_URL=http://localhost:4000/api

# Razorpay Client-Side Key ID
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id_here

# API Gateway Client Credentials for Session Authorization
VITE_CLIENT_ID=your_gateway_client_id_here
VITE_CLIENT_SECRET=your_gateway_client_secret_here
