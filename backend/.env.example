# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/talent-ecosystem
MONGODB_URI=mongodb://localhost:27017/talent-ecosystem

# Server Configuration
PORT=5000
NODE_ENV=development

# AI API Keys
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
PRACTICAL_GROQ_KEY=your_practical_groq_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Firebase Admin SDK (for authentication)
# Download your service account JSON from Firebase Console and paste the path here
FIREBASE_SERVICE_ACCOUNT_PATH=./config/serviceAccountKey.json

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number
BASE_URL=http://localhost:5000

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Cal.com Webhook Integration
CAL_WEBHOOK_URL=http://localhost:5000/api/cal-webhook
CAL_WEBHOOK_SECRET=your_cal_webhook_secret

# News API Configuration
NEWS_API_KEY=your_news_api_key_here

# Security & JWT Tokens
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_key_change_this_in_production

# ElevenLabs Podcast/Broadcaster Voice Overrides (Optional custom voice IDs)
VOICE_ROGAN_ID=your_elevenlabs_id_here
VOICE_BROADCASTER_ID=your_elevenlabs_id_here
VOICE_PODCAST_HOST_ID=your_elevenlabs_id_here
VOICE_COHOST_ID=your_elevenlabs_id_here

